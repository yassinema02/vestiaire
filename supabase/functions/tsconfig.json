{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "allowImportingTsExtensions": true
  },
  "include": [
    "**/*.ts",
    "globals.d.ts"
  ]
}
